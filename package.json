{
  "name": "code-mode-engine",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "dev:mock": "tsx packages/mock-api/src/server.ts",
    "dev:server": "tsx packages/mcp-server/src/server.ts",
    "dev:chat": "tsx packages/chat-backend/src/server.ts",
    "dev:widget": "pnpm --filter widget dev",
    "build:widget": "pnpm --filter widget build",
    "start": "ENGINE_CONFIG=engine.config.prod.json tsx packages/chat-backend/src/server.ts"
  },
  "devDependencies": {
    "@ai-sdk/react": "^3.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^22.0.0",
    "ai": "^6.0.0",
    "jsdom": "^25.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
