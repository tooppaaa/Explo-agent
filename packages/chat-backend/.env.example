# ── Provider LLM ─────────────────────────────────────────────────────────────
# CHAT_PROVIDER=anthropic   # "anthropic" (défaut) ou "mistral"

# Anthropic (défaut)
ANTHROPIC_API_KEY=sk-ant-...
# CHAT_MODEL=claude-sonnet-4-5   # défaut si provider=anthropic

# Mistral (décommenter CHAT_PROVIDER=mistral pour l'activer)
# MISTRAL_API_KEY=...
# CHAT_MODEL=mistral-medium-latest   # défaut si provider=mistral

# ── Serveur ───────────────────────────────────────────────────────────────────
# CHAT_PORT=3000
# ENGINE_CONFIG=engine.config.json

# ── Observabilité (Langfuse, optionnel) ──────────────────────────────────────
# Renseigner les 2 clés active l'export OTel→Langfuse (traces LLM + tool calls,
# code généré, __ui, coût, latence). Laisser vide = désactivé.
# Clés : Langfuse → Settings → API Keys.
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASEURL=https://cloud.langfuse.com   # ou https://us.cloud.langfuse.com / self-hosted
