# Clé API Anthropic (obligatoire)
ANTHROPIC_API_KEY=sk-ant-...

# Modèle à utiliser (optionnel, défaut : claude-sonnet-4-5)
# CHAT_MODEL=claude-sonnet-4-5

# Port d'écoute du chat backend (optionnel, défaut : 3000)
# CHAT_PORT=3000

# Chemin vers la config providers (optionnel, défaut : ./engine.config.json)
# ENGINE_CONFIG=engine.config.json
