# Port d'écoute du serveur MCP (optionnel, défaut : 3000)
# MCP_PORT=3000

# Chemin vers la config providers (optionnel, défaut : ./engine.config.json)
# ENGINE_CONFIG=engine.config.json

# Credential de service pour l'authentification d'un provider (si auth configurée)
# La clé correspond à auth.tokenEnv ou auth.valueEnv dans engine.config.json.
# Exemple si engine.config.json contient { "auth": { "type": "bearer", "tokenEnv": "MY_API_KEY" } } :
# MY_API_KEY=...
